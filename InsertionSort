#include <iostream>
using namespace std;

void Nhap(int a[], int &n) {
    cin >> n;
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
}
void InsertionSort(int a[], int n) {
    for (int i = 1; i < n; i++) {
        int x = a[i];
        int k = i - 1;
        while (k >= 0 && a[k] > x) {
            a[k + 1] = a[k];  
            for (int t = 0; t < n; t++)
                cout << a[t] << " ";
            cout << endl;
            k--;
        }
        a[k + 1] = x;
        for (int t = 0; t < n; t++)
            cout << a[t] << " ";
        cout << endl;
    }
}
int main() {
    int a[1000], n;
    Nhap(a, n);
    InsertionSort(a, n);
    return 0;
}
