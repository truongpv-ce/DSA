#include <iostream>
using namespace std;
void search(int arr[], int n, int x) {
    bool found = false;
    for (int i = 0; i < n; i++) {
        if (arr[i] == x) {
            cout << i << endl;
            cout << i + 1 << endl;
            found = true;
            break;
        }
    }
    if (!found) {
        cout << -1 << endl;
        return;
    }
    for (int i = n - 1; i >= 0; i--) {
        if (arr[i] == x) {
            cout << n - i - 1 << endl;
            cout << n - i << endl;
            break;
        }
    }
}
int main() {
    int arr[100001], n, x;
    cin >> n;
    for (int i = 0; i < n; i++)
        cin >> arr[i];
    cin >> x;
    search(arr, n, x);
    return 0;
}
