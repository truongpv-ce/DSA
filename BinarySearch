#include <iostream>
#include <algorithm>
using namespace std;

bool myBinarySearch(int a[], int n, int x);

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    int n, q; cin >> n >> q;
    int arr[100];
    for (int i = 0; i < n; i++)
        cin >> arr[i];
    sort(arr, arr + n);
    int x;
    while (q--) {
        cin >> x;
        if (myBinarySearch(arr, n, x))
            cout << "YES\n";
        else cout << "NO\n";
    }
    return 0;
}
bool myBinarySearch(int a[], int n, int x) {
    int L = 0, R = n - 1;
    while (L <= R) {
        int mid = (L + R) / 2;
        if (a[mid] == x) {
            return true;
        }
        if (a[mid] > x) {
            R = mid - 1;
        }
        else {
            L = mid + 1;
        }
    }
    return false;
}


