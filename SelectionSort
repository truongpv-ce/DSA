#include <iostream>
using namespace std;
    
void Nhap(int a[], int& n) {
    cin >> n;
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
}
void SelectionSort(int a[], int n) {
    int min;
    for (int i = 0; i < n - 1; i++) {
        min = i;
        for (int j = i + 1; j < n; j++) {
            if (a[j] < a[min]) {
                min = j;
            }
        }
        if (min != i) {
            swap(a[i], a[min]);
            for (int k = 0; k < n; k++) {
                cout << a[k] << " ";
            }
            cout << endl;
        }
    }
}
int main() {
    int a[1000], n;
    Nhap(a, n);
    SelectionSort(a, n);
    return 0;
}
